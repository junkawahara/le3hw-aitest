// SIMPLE/B テストプログラム
// r0 を 1 ずつインクリメントし、遅延ループ付きで OUT する
//
// addr  hex   instruction
// 0     8000  LI r0, 0        ; カウンタ
// 1     8101  LI r1, 1        ; インクリメント値
// 2     840A  LI r4, 10       ; 外側ループ回数
// 3     C800  ADD r0, r1      ; r0++
// 4     C0D0  OUT r0          ; 出力
// 5     8300  LI r3, 0        ; 外側カウンタ
// 6     8200  LI r2, 0        ; 内側カウンタ
// 7     CA00  ADD r2, r1      ; r2++
// 8     BBFE  BNE -2          ; r2!=0 なら addr 7 へ (65536回)
// 9     CB00  ADD r3, r1      ; r3++
// 10    E350  CMP r3, r4      ; r3 と 10 を比較
// 11    B9FA  BLT -6          ; r3<10 なら addr 6 へ
// 12    A0F6  B -10           ; addr 3 へ戻る
8000
8101
840A
C800
C0D0
8300
8200
CA00
BBFE
CB00
E350
B9FA
A0F6
