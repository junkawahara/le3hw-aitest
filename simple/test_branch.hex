// 分岐テスト: r0を3回インクリメントして出力
// 0: LI r0, 0       8000
// 1: LI r1, 1       8101
// 2: LI r4, 3       8403
// 3: ADD r0, r1     C800  (loop)
// 4: CMP r0, r4     E050  (11_100_000_0101_0000: Rs=r4, Rd=r0)
// 5: BLT -3         B9FD  (10_111_001_11111101: cond=BLT, d=-3 → addr 3)
// 6: OUT r0         C0D0  (r0 should be 3)
// 7: HLT            C0F0
8000
8101
8403
C800
E050
B9FD
C0D0
C0F0
